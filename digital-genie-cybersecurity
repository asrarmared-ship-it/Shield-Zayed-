# Install additional useful tools
install_additional_tools() {
    print_header "تثبيت أدوات إضافية"
    
    # Code editors and IDEs
    print_status "تثبيت محررات النصوص والـ IDEs..."
    
    # VS Code
    if [[ $PACKAGE_MANAGER == "apt" ]]; then
        wget -qO- https://packages.microsoft.com/keys/microsoft.asc | gpg --dearmor > packages.microsoft.gpg
        sudo install -o root -g root -m 644 packages.microsoft.gpg /etc/apt/trusted.gpg.d/
        echo "deb [arch=amd64,arm64,armhf signed-by=/etc/apt/trusted.gpg.d/packages.microsoft.gpg] https://packages.microsoft.com/repos/code stable main" | sudo tee /etc/apt/sources.list.d/vscode.list
        sudo apt update
        $INSTALL_CMD code
    fi
    
    # Sublime Text
    if [[ $PACKAGE_MANAGER == "apt" ]]; then
        wget -qO - https://download.sublimetext.com/sublimehq-pub.gpg | sudo apt-key add -
        echo "deb https://download.sublimetext.com/ apt/stable/" | sudo tee /etc/apt/sources.list.d/sublime-text.list
        sudo apt update
        $INSTALL_CMD sublime-text
    fi
    
    # Database tools
    $INSTALL_CMD mysql-client postgresql-client mongodb-clients redis-tools
    
    # Monitoring tools
    $INSTALL_CMD iftop iotop nethogs nload vnstat
}

# Configure firewall
configure_firewall() {
    print_header "تكوين جدار الحماية"
    
    # Install and configure UFW (Uncomplicated Firewall)
    $INSTALL_CMD ufw
    
    # Enable UFW
    sudo ufw --force enable
    
    # Allow SSH
    sudo ufw allow ssh
    
    # Allow HTTP and HTTPS
    sudo ufw allow 80
    sudo ufw allow 443
    
    # Set default policies
    sudo ufw default deny incoming
    sudo ufw default allow outgoing
    
    print_status "تم تكوين جدار الحماية بنجاح"
}

# Setup aliases and shortcuts
setup_aliases() {
    print_header "إعداد الاختصارات والأوامر المفيدة"
    
    cat >> ~/.bashrc << 'EOF'

# Security Lab Aliases
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'
alias ..='cd ..'
alias ...='cd ../..'
alias grep='grep --color=auto'
alias fgrep='fgrep --color=auto'
alias egrep='egrep --color=auto'

# Network aliases
alias ports='netstat -tulanp'
alias listening='netstat -tlnp'
alias ping='ping -c 5'
alias fastping='ping -c 100 -s 2'

# Security aliases
alias nmap-quick='nmap -T4 -F'
alias nmap-intense='nmap -T4 -A -v'
alias nmap-intense-udp='nmap -sS -sU -T4 -A -v'
alias nmap-intense-all-tcp='nmap -p 1-65535 -T4 -A -v'

# System monitoring
alias topcpu='ps -eo pid,ppid,cmd,%mem,%cpu --sort=-%cpu | head'
alias topmem='ps -eo pid,ppid,cmd,%mem,%cpu --sort=-%mem | head'
alias disk='df -h'
alias meminfo='free -m -l -t'

# Git shortcuts
alias gs='git status'
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias gl='git log --oneline'

EOF

    source ~/.bashrc
}

# Final system optimization
optimize_system() {
    print_header "تحسين النظام"
    
    # Update locate database
    sudo updatedb 2>/dev/null || true
    
    # Clean package cache
    if [[ $PACKAGE_MANAGER == "apt" ]]; then
        sudo apt autoremove -y
        sudo apt autoclean
    elif [[ $PACKAGE_MANAGER == "dnf" ]]; then
        sudo dnf autoremove -y
        sudo dnf clean all
    fi
    
    # Set proper file permissions
    chmod 700 ~/.ssh 2>/dev/null || true
    chmod 600 ~/.ssh/authorized_keys 2>/dev/null || true
    
    print_status "تم تحسين النظام بنجاح"
}

# Main execution function
main() {
    print_header "بدء إعداد مختبر الأمن السيبراني"
    print_status "هذا السكريبت سيقوم بتحديث النظام وتثبيت جميع الأدوات اللازمة"
    
    read -p "هل تريد المتابعة؟ (y/N): " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        print_warning "تم إلغاء العملية"
        exit 1
    fi
    
    check_root
    
    print_status "بدء العملية..."
    
    update_system
    install_dev_tools
    install_python
    install_nodejs
    install_go
    install_rust
    install_java
    install_docker
    install_security_tools
    install_additional_tools
    configure_firewall
    setup_aliases
    optimize_system
    
    print_header "تم الانتهاء بنجاح!"
    print_status "تم تثبيت جميع الأدوات والمكتبات اللازمة لمختبر الأمن السيبراني"
    print_warning "يرجى إعادة تسجيل الدخول أو تشغيل 'source ~/.bashrc' لتفعيل التغييرات"
    print_status "مجلد أدوات الأمان: ~/security-tools"
    
    echo -e "\n${GREEN}الأدوات المثبتة تشمل:${NC}"
    echo "- لغات البرمجة: Python, Node.js, Go, Rust, Java"
    echo "- أدوات الشبكة: nmap, masscan, netcat, tcpdump"
    echo "- أدوات الاختراق: hydra, john, hashcat, sqlmap"
    echo "- بيئة التطوير: VS Code, Docker, Git"
    echo "- أدوات المراقبة: htop, iftop, nethogs"
    echo "- جدار الحماية: UFW مفعل ومكوّن"
}

# Execute main function
main "$@"

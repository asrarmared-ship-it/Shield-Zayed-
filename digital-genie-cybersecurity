# Install Node.js and npm
install_nodejs() {
    print_header "تثبيت Node.js و npm"
    
    # Install Node Version Manager (nvm)
    curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.0/install.sh | bash
    source ~/.bashrc
    
    # Install latest LTS Node.js
    if command -v nvm &> /dev/null; then
        nvm install --lts
        nvm use --lts
    else
        # Fallback to package manager installation
        if [[ $PACKAGE_MANAGER == "apt" ]]; then
            curl -fsSL https://deb.nodesource.com/setup_lts.x | sudo -E bash -
            $INSTALL_CMD nodejs
        else
            $INSTALL_CMD nodejs npm
        fi
    fi
    
    # Install useful npm packages
    npm install -g @angular/cli vue-cli create-react-app typescript eslint prettier nodemon pm2
}

# Install Go programming language
install_go() {
    print_header "تثبيت لغة Go"
    
    GO_VERSION="1.21.5"
    wget -O /tmp/go.tar.gz "https://golang.org/dl/go${GO_VERSION}.linux-amd64.tar.gz"
    sudo rm -rf /usr/local/go
    sudo tar -C /usr/local -xzf /tmp/go.tar.gz
    
    # Add Go to PATH
    echo 'export PATH=$PATH:/usr/local/go/bin' >> ~/.bashrc
    echo 'export GOPATH=$HOME/go' >> ~/.bashrc
    echo 'export PATH=$PATH:$GOPATH/bin' >> ~/.bashrc
    
    source ~/.bashrc
    
    rm /tmp/go.tar.gz
}

# Install Rust programming language
install_rust() {
    print_header "تثبيت لغة Rust"
    
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
    source ~/.cargo/env
    
    # Add Rust to PATH
    echo 'source ~/.cargo/env' >> ~/.bashrc
}

# Install Java Development Kit
install_java() {
    print_header "تثبيت Java JDK"
    
    if [[ $PACKAGE_MANAGER == "apt" ]]; then
        $INSTALL_CMD openjdk-17-jdk openjdk-11-jdk
    else
        $INSTALL_CMD java-17-openjdk-devel java-11-openjdk-devel
    fi
    
    # Set JAVA_HOME
    echo 'export JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64' >> ~/.bashrc
    echo 'export PATH=$PATH:$JAVA_HOME/bin' >> ~/.bashrc
}

# Install Docker
install_docker() {
    print_header "تثبيت Docker"
    
    if [[ $PACKAGE_MANAGER == "apt" ]]; then
        # Remove old versions
        sudo apt remove docker docker-engine docker.io containerd runc 2>/dev/null || true
        
        # Add Docker's official GPG key
        curl -fsSL https://download.docker.com/linux/ubuntu/gpg | sudo gpg --dearmor -o /usr/share/keyrings/docker-archive-keyring.gpg
        
        # Add Docker repository
        echo "deb [arch=amd64 signed-by=/usr/share/keyrings/docker-archive-keyring.gpg] https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable" | sudo tee /etc/apt/sources.list.d/docker.list > /dev/null
        
        sudo apt update
        $INSTALL_CMD docker-ce docker-ce-cli containerd.io docker-compose-plugin
    else
        $INSTALL_CMD docker docker-compose
    fi
    
    # Add user to docker group
    sudo usermod -aG docker $USER
    
    # Enable Docker service
    sudo systemctl enable docker
    sudo systemctl start docker
}

# Install security tools
install_security_tools() {
    print_header "تثبيت أدوات الأمن السيبراني"
    
    # Network security tools
    NETWORK_TOOLS=(
        "nmap"
        "masscan"
        "zmap"
        "netcat"
        "socat"
        "tcpdump"
        "wireshark-cli"
        "aircrack-ng"
        "hashcat"
        "john"
        "hydra"
        "medusa"
        "nikto"
        "dirb"
        "gobuster"
        "wfuzz"
        "sqlmap"
        "metasploit-framework"
    )
    
    # Install available tools
    for tool in "${NETWORK_TOOLS[@]}"; do
        print_status "تثبيت $tool..."
        $INSTALL_CMD "$tool" 2>/dev/null || print_warning "فشل في تثبيت $tool أو غير متوفر في المستودع"
    done
    
    # Install additional security tools from GitHub
    mkdir -p ~/security-tools
    cd ~/security-tools
    
    # Clone useful security repositories
    print_status "تحميل أدوات الأمان من GitHub..."
    
    # SecLists - Security testing wordlists
    git clone https://github.com/danielmiessler/SecLists.git
    
    # PayloadsAllTheThings
    git clone https://github.com/swisskyrepo/PayloadsAllTheThings.git
    
    # OWASP ZAP Baseline scan
    git clone https://github.com/zaproxy/zaproxy.git
    
    # Sublist3r - Subdomain enumeration
    git clone https://github.com/aboul3la/Sublist3r.git
    cd Sublist3r && pip3 install -r requirements.txt && cd ..
    

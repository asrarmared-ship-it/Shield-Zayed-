# ─────────────────────────────────────────────────────────────────────────
# OWASP Dependency Check - Vulnerability Scanner
# ─────────────────────────────────────────────────────────────────────────
[submodule "modules/security/owasp-dependency-check"]
	path = modules/security/owasp-dependency-check
	url = https://github.com/jeremylong/DependencyCheck.git
	branch = main
	shallow = true
	update = rebase

